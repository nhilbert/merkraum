{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.nhilbert/merkraum",
  "title": "Merkraum",
  "description": "Auditable knowledge memory for AI agents with belief tracking and contradiction detection.",
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "merkraum",
      "version": "1.0.0",
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:8090/mcp"
      },
      "environmentVariables": [
        { "name": "NEO4J_URI", "description": "Neo4j bolt URI (e.g. bolt://localhost:7687)", "required": true },
        { "name": "NEO4J_USER", "description": "Neo4j username", "required": true },
        { "name": "NEO4J_PASSWORD", "description": "Neo4j password", "required": true },
        { "name": "QDRANT_URL", "description": "Qdrant REST URL (e.g. http://localhost:6333)", "required": true },
        { "name": "OPENAI_API_KEY", "description": "OpenAI API key for LLM-powered text ingestion", "required": false }
      ]
    }
  ]
}
