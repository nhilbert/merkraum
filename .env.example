# Merkraum Local Configuration
# Copy to .env and adjust as needed.
# v1.0 — Z1142 (2026-03-07)

# Backend type: neo4j_qdrant (local) or neo4j_pinecone (cloud)
MERKRAUM_BACKEND=neo4j_qdrant

# Neo4j (local Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=merkraum-local

# Qdrant (local Docker)
QDRANT_URL=http://localhost:6333

# Embedding model (fastembed, runs locally — no API key needed)
EMBED_MODEL=BAAI/bge-small-en-v1.5

# OpenAI API key (required for /api/ingest/text — LLM-based extraction)
# OPENAI_API_KEY=sk-...

# Cognito JWT validation (for all endpoints, when AUTH_REQUIRED=true)
# Get these from AWS Cognito console
COGNITO_USER_POOL_ID=<your-user-pool-id>
COGNITO_AWS_REGION=<your-aws-region>
COGNITO_CLIENT_ID=<your-client-id>

# Authentication enforcement
# true = All endpoints require valid Authorization: Bearer <token> header (production)
# false/unset = Endpoints work without authentication (local development, default)
AUTH_REQUIRED=false
