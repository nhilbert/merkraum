# Merkraum Local Configuration
# Copy to .env and adjust as needed.
# v1.0 — Z1142 (2026-03-07)

# Backend type: neo4j_qdrant (local) or neo4j_pinecone (cloud)
MERKRAUM_BACKEND=neo4j_qdrant

# Neo4j (local Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=merkraum-local

# Qdrant (local Docker)
QDRANT_URL=http://localhost:6333

# Embedding model (fastembed, runs locally — no API key needed)
EMBED_MODEL=BAAI/bge-small-en-v1.5

# OpenAI API key (required for /api/ingest/text — LLM-based extraction)
# OPENAI_API_KEY=sk-...

# Cognito JWT validation (for all endpoints, when AUTH_REQUIRED=true)
# Get these from AWS Cognito console
COGNITO_USER_POOL_ID=<your-user-pool-id>
COGNITO_AWS_REGION=<your-aws-region>
COGNITO_CLIENT_ID=<your-client-id>

# Authentication enforcement
# If AUTH_REQUIRED is unset, auth is ON by default.
# Set DEV_MODE=true for local development to allow auth bypass by default.
# AUTH_REQUIRED=false
# DEV_MODE=true

# Token type accepted from Cognito ('id', 'access', or comma-separated both)
COGNITO_TOKEN_USE=id

# Production guardrails
# APP_ENV=production enforces AUTH_REQUIRED=true and COGNITO_CLIENT_ID presence at startup
# APP_ENV=production

# Project authorization controls (used when AUTH_REQUIRED=true)
# Admin groups may access all projects
# ADMIN_GROUPS=admins,platform-admins
# Allow everyone with valid token to access default project (default is false)
# ALLOW_DEFAULT_PROJECT=true

# MCP OAuth configuration (required when running merkraum_mcp_server.py in non-dev mode)
# MCP_BASE_URL=https://example.com/mcp/merkraum
# COGNITO_AUTH_DOMAIN=https://<your-domain>.auth.<region>.amazoncognito.com
# MCP_COGNITO_CLIENT_ID=<your-mcp-client-id>
# MCP_ALLOWED_CLIENT_IDS=<client-id-1>,<client-id-2>
# Disable open dynamic registration by default (set true only with additional controls)
# MCP_ENABLE_DYNAMIC_CLIENT_REGISTRATION=false
# CORS allowlist for browser requests (comma-separated origins)
# CORS_ALLOWED_ORIGINS=https://app.merkraum.de,https://staging.merkraum.de
# Optional explicit ACL maps:
# PROJECT_GROUP_ACL_JSON={"project-a":["team-a"],"project-b":["team-b","admins"]}
# PROJECT_USER_ACL_JSON={"project-a":["user-sub-1","user-sub-2"]}
